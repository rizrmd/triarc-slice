[sub_resource type="Shader" id="shader_energy_fill"]
code = "shader_type canvas_item;
uniform float fill_amount : hint_range(0.0, 1.0) = 1.0;
const float FILL_TOP = 0.2906;
const float FILL_BOTTOM = 0.6792;
void fragment() {
    COLOR = texture(TEXTURE, UV);
    if (UV.y > FILL_TOP && UV.y < FILL_BOTTOM) {
        float cutoff = FILL_BOTTOM - fill_amount * (FILL_BOTTOM - FILL_TOP);
        if (UV.y < cutoff) {
            COLOR.a = 0.0;
        }
    }
}"

[sub_resource type="ShaderMaterial" id="mat_energy_fill"]
shader = SubResource("shader_energy_fill")
shader_parameter/fill_amount = 1.0

